# Supabase project shared with operation.moosivabh.com
# Public/anon values only — never put the service role key in a
# NEXT_PUBLIC_ variable.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (no NEXT_PUBLIC_ prefix). Used by lib/supabase/admin.ts,
# imported only from Server Actions, to insert website_order_requests rows
# — that table has no anon RLS policies by design. Never expose this to the
# browser or import lib/supabase/admin.ts from a "use client" file.
SUPABASE_SERVICE_ROLE_KEY=

# Public site metadata
NEXT_PUBLIC_SITE_URL=https://www.moosivabh.com

# Moosiva WhatsApp number for the WhatsApp CTA and checkout handoff.
# Digits only or E.164, e.g. 97312345678.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Optional: shown in the footer when set.
NEXT_PUBLIC_INSTAGRAM_URL=
